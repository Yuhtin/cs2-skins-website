# Server branding (shown in header + login page)
VITE_SERVER_NAME="CS2 Weapon Paints"

# Optional: CS2 connect link for login page badge
# VITE_SERVER_URL="steam://connect/ip.address:27015"

# Optional: Discord invite for login page badge
# VITE_DISCORD_URL="https://discord.gg/yourinvite"

# API base path (rarely changed; default /api)
VITE_API_URL=/api

# Dev server proxy target — where `npm run dev` forwards /api calls.
# Default: http://localhost:8080 (e.g. local php-fpm or docker container)
# VITE_DEV_PROXY_TARGET="https://your.prod.domain.com"
